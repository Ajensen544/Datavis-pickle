{
    "$schema": "https://raw.githubusercontent.com/revisit-studies/study/main/src/parser/StudyConfigSchema.json",
    "studyMetadata": {
        "title": "Basic Questionnaire Study",
        "version": "pilot",
        "authors": [
            "The reVISit Team"
        ],
        "date": "2024-03-19",
        "description": "A simple questionnaire study",
        "organizations": [
            "University of Utah",
            "WPI"
        ]
    },
    "uiConfig": {
        "contactEmail": "contact@revisit.dev",
        "helpTextPath": "basic-questionnaire-study/assets/help.md",
        "logoPath": "revisitAssets/revisitLogoSquare.svg",
        "withProgressBar": true,
        "autoDownloadStudy": false,
        "withSidebar": true
    },
    "baseComponents": {
        "pickletrial": {
            "description": "pickleball court react component",
            "instruction": "Click where you think the pickleball will land",
            "type": "react-component",
            "path": "basic-questionnaire-study/assets/pickletrial.tsx",
            "nextButtonLocation": "sidebar",
            "response": [
                {
                    "id": "pickleballAnswer",
                    "prompt": "",
                    "location": "belowStimulus",
                    "type": "reactive",
                    "hidden": true
                }
            ]
        }
    },
    "components": {
        "introduction": {
            "type": "markdown",
            "path": "basic-questionnaire-study/assets/introduction.md",
            "response": []
        },
        "demographics": {
            "type": "questionnaire",
            "response": [
                {
                    "id": "age",
                    "prompt": "What is your age?",
                    "required": true,
                    "location": "aboveStimulus",
                    "type": "numerical",
                    "placeholder": "Please enter your age"
                },
                {
                    "id": "gender",
                    "prompt": "What is your gender?",
                    "required": true,
                    "location": "aboveStimulus",
                    "type": "dropdown",
                    "placeholder": "Please select your gender",
                    "options": [
                        "Male",
                        "Female",
                        "Non-binary",
                        "Prefer not to say"
                    ]
                },
                {
                    "id": "paddleExperience",
                    "prompt": "How many years of experience do you have playing a paddle sport?",
                    "required": true,
                    "location": "aboveStimulus",
                    "type": "numerical",
                    "placeholder": "Please enter your years of experience"
                },
                {
                    "id": "vision",
                    "prompt": "Do you have any vision impairments?",
                    "required": true,
                    "location": "aboveStimulus",
                    "type": "dropdown",
                    "placeholder": "Please select your vision status",
                    "options": [
                        "No",
                        "Corrective lenses",
                        "Visually impaired"
                    ]
                }
            ]
        },
        "descriptions": {
            "type": "markdown",
            "path": "basic-questionnaire-study/assets/desc.md",
            "response": []
        },
        "postsurvey": {
            "type": "questionnaire",
            "response": [
                {
                    "id": "enjoyment",
                    "prompt": "How much did you enjoy this survey?",
                    "required": true,
                    "location": "aboveStimulus",
                    "type": "dropdown",
                    "placeholder": "Please select your enjoyment level",
                    "options": [
                        "Very Enjoyed",
                        "Enjoyed",
                        "Neutral",
                        "Disliked",
                        "Very Disliked"
                    ]
                },
                {
                    "id": "feedback",
                    "prompt": "Please provide any feedback you have about this survey.",
                    "required": false,
                    "location": "aboveStimulus",
                    "type": "longText",
                    "placeholder": "Your feedback is appreciated!"
                }
            ]
        },
        "conclusion": {
            "type": "markdown",
            "path": "basic-questionnaire-study/assets/conc.md",
            "response": []
        },
